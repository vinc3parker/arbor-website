<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Arbor — The Eight Dimensions</title>
<style>
  :root{
    --bg:#07080a;
    --ink:#f3efe7;
    --muted:#8b8578;
    --ease:cubic-bezier(.22,.61,.36,1);
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow:hidden;
    letter-spacing:.01em;
  }

  /* ---------- Room / atmosphere ---------- */
  .scene{
    position:fixed;
    inset:0;
    perspective:1600px;
    perspective-origin:50% 46%;
    overflow:hidden;
  }
  /* layered lighting — dome, warm wash, floor, vignette */
  .atmos{position:absolute;inset:0;pointer-events:none}
  .atmos.dome{
    background:
      radial-gradient(120% 80% at 50% -10%, rgba(60,54,44,.55), rgba(9,9,11,0) 60%);
  }
  .atmos.warm{
    background:
      radial-gradient(60% 45% at 50% 40%, rgba(120,96,60,.16), rgba(0,0,0,0) 70%);
    mix-blend-mode:screen;
  }
  .atmos.floor{
    background:
      radial-gradient(80% 55% at 50% 118%, rgba(46,42,34,.9), rgba(7,8,10,0) 60%),
      linear-gradient(to top, rgba(0,0,0,.6), rgba(0,0,0,0) 34%);
  }
  .atmos.vignette{
    background:radial-gradient(130% 100% at 50% 45%, rgba(0,0,0,0) 55%, rgba(0,0,0,.72) 100%);
  }
  .grain{
    position:absolute;inset:-50%;pointer-events:none;opacity:.04;mix-blend-mode:overlay;
    background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='2'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }

  /* camera + curved wall of windows */
  .camera{
    position:absolute;inset:0;
    transform-style:preserve-3d;
    transform:rotateX(var(--look-y,0deg)) rotateY(var(--look-x,0deg));
    transition:transform 1.4s var(--ease);
    will-change:transform;
  }
  .wall{
    position:absolute;left:50%;top:50%;
    width:0;height:0;
    transform-style:preserve-3d;
    transform:translateZ(-180px);
  }
  .window{
    position:absolute;
    width:190px;height:380px;
    margin:-190px 0 0 -95px;      /* centre on origin */
    transform-style:preserve-3d;
    cursor:pointer;
    color:var(--accent);
    transition:opacity 1s var(--ease), filter 1s var(--ease);
  }
  .win-glass{
    position:absolute;inset:0;
    border-radius:95px 95px 88px 88px;
    overflow:hidden;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 14%, #0c0d10) 0%, #0a0b0e 78%);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent),
      inset 0 40px 80px rgba(0,0,0,.55),
      0 30px 90px rgba(0,0,0,.6);
    transition:box-shadow 1s var(--ease), transform 1s var(--ease);
  }
  /* frame / sill */
  .win-frame{
    position:absolute;inset:-10px;
    border-radius:105px 105px 96px 96px;
    box-shadow:
      inset 0 0 0 1px rgba(255,255,255,.05),
      0 1px 0 rgba(255,255,255,.04);
    pointer-events:none;
  }
  .win-glow{
    position:absolute;inset:-30% -20%;
    background:radial-gradient(60% 50% at 50% 42%, color-mix(in srgb, var(--accent) 40%, transparent), transparent 70%);
    opacity:0;filter:blur(14px);transition:opacity 1s var(--ease);
    pointer-events:none;
  }
  .win-art{position:absolute;inset:0;display:block}
  .win-art svg{width:100%;height:100%;display:block}
  .win-art svg [stroke]{vector-effect:non-scaling-stroke}

  /* label */
  .win-label{
    position:absolute;left:50%;top:calc(100% + 22px);
    transform:translateX(-50%) translateY(6px);
    width:220px;text-align:center;
    opacity:0;transition:opacity .7s var(--ease), transform .7s var(--ease);
    pointer-events:none;
  }
  .win-label .name{font-size:19px;font-weight:600;letter-spacing:.02em}
  .win-label .dim{
    margin-top:5px;font-size:10.5px;letter-spacing:.32em;text-transform:uppercase;
    color:color-mix(in srgb, var(--accent) 70%, #cfc8ba);
  }
  .win-label .say{margin-top:9px;font-size:13px;color:var(--muted)}

  /* interaction states */
  .stage.has-hover .window{opacity:.32;filter:saturate(.7) brightness(.7)}
  .window.active{opacity:1 !important;filter:none !important}
  .window.active .win-glass{
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--accent) 65%, transparent),
      inset 0 30px 70px rgba(0,0,0,.4),
      0 40px 120px color-mix(in srgb, var(--accent) 22%, rgba(0,0,0,.6));
    transform:translateY(-4px);
  }
  .window.active .win-glow{opacity:.9}
  .window.active .win-label{opacity:1;transform:translateX(-50%) translateY(0)}

  /* ---------- Pedestal + Arbor mark ---------- */
  .pedestal{
    position:absolute;left:50%;bottom:8%;
    transform:translateX(-50%);
    display:flex;flex-direction:column;align-items:center;
    z-index:4;pointer-events:none;
    transition:opacity 1s var(--ease), transform 1.2s var(--ease);
  }
  .mark{
    width:66px;height:66px;
    filter:drop-shadow(0 8px 30px rgba(0,0,0,.6));
    opacity:.96;
  }
  .plinth{
    margin-top:16px;width:280px;height:60px;
    border-radius:50%;
    background:
      radial-gradient(60% 100% at 50% 0%, rgba(120,104,74,.35), rgba(0,0,0,0) 70%),
      radial-gradient(50% 90% at 50% 30%, rgba(20,19,16,.9), rgba(7,8,10,0) 72%);
    box-shadow:0 -1px 0 rgba(255,255,255,.05);
  }
  .mark-halo{
    position:absolute;top:-26px;left:50%;transform:translateX(-50%);
    width:200px;height:200px;border-radius:50%;
    background:radial-gradient(circle, rgba(150,128,86,.18), rgba(0,0,0,0) 62%);
    filter:blur(6px);
  }

  /* ---------- Text overlay ---------- */
  .heading{
    position:absolute;left:0;right:0;top:9%;
    text-align:center;z-index:5;pointer-events:none;
    transition:opacity .9s var(--ease), transform .9s var(--ease);
  }
  .heading h1{
    margin:0;font-weight:600;font-size:clamp(26px,3.4vw,46px);
    letter-spacing:.005em;
  }
  .heading p{
    margin:14px 0 0;color:var(--muted);font-size:clamp(13px,1.4vw,17px);
    font-weight:400;letter-spacing:.02em;
  }
  .hint{
    position:absolute;left:0;right:0;bottom:3.5%;text-align:center;
    font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:#4c483f;
    z-index:5;pointer-events:none;transition:opacity .8s var(--ease);
  }

  .stage.zooming .heading{opacity:0;transform:translateY(-10px)}
  .stage.zooming .hint{opacity:0}
  .stage.zooming .pedestal{opacity:0;transform:translateX(-50%) translateY(20px) scale(.96)}
  .stage.zooming .camera{filter:blur(7px);opacity:.35;transform:scale(1.22) rotateX(var(--look-y,0deg)) rotateY(var(--look-x,0deg));transition:transform 1.1s var(--ease), opacity 1.1s var(--ease), filter 1.1s var(--ease)}

  /* ---------- Portal (travel through the window) ---------- */
  .portal{
    position:fixed;z-index:20;overflow:hidden;
    border-radius:95px 95px 88px 88px;
    color:var(--accent);
    box-shadow:0 40px 160px rgba(0,0,0,.7);
    transition:top 1s var(--ease), left 1s var(--ease), width 1s var(--ease),
               height 1s var(--ease), border-radius 1s var(--ease);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--accent) 16%, #0a0b0e) 0%, #08090c 82%);
  }
  .portal.is-open{top:0!important;left:0!important;width:100vw!important;height:100vh!important;border-radius:0}
  .portal-art{position:absolute;inset:0;opacity:.5;transition:opacity 1s var(--ease)}
  .portal-art svg{width:100%;height:100%}
  .portal.is-open .portal-art{opacity:.16}
  .portal-wash{position:absolute;inset:0;background:radial-gradient(80% 70% at 50% 40%, color-mix(in srgb,var(--accent) 14%, transparent), transparent 75%);pointer-events:none}

  .landing{
    position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;
    padding:0 8vw;max-width:900px;margin:0 auto;left:0;right:0;
    opacity:0;transform:translateY(18px);
    transition:opacity .8s var(--ease) .1s, transform .8s var(--ease) .1s;
    color:var(--ink);
  }
  .portal.show .landing{opacity:1;transform:none}
  .landing .kicker{font-size:11px;letter-spacing:.34em;text-transform:uppercase;color:color-mix(in srgb,var(--accent) 78%, #d8d2c6)}
  .landing h2{margin:16px 0 0;font-size:clamp(40px,7vw,84px);font-weight:600;line-height:1;color:var(--ink)}
  .landing .lede{margin:22px 0 0;font-size:clamp(16px,2vw,22px);color:#cfc8ba;max-width:34ch;line-height:1.5}
  .landing .enter{
    margin-top:38px;display:inline-flex;align-items:center;gap:10px;width:max-content;
    font-size:14px;letter-spacing:.04em;color:var(--accent);
    padding:13px 22px;border-radius:100px;
    border:1px solid color-mix(in srgb,var(--accent) 45%, transparent);
    background:color-mix(in srgb,var(--accent) 8%, transparent);
  }
  .close{
    position:absolute;top:26px;right:30px;z-index:3;
    width:42px;height:42px;border-radius:50%;cursor:pointer;
    border:1px solid rgba(255,255,255,.16);background:rgba(0,0,0,.25);
    color:#e9e4da;font-size:18px;line-height:1;display:grid;place-items:center;
    opacity:0;transition:opacity .6s var(--ease) .4s;backdrop-filter:blur(6px);
  }
  .portal.show .close{opacity:1}
  .close:hover{border-color:rgba(255,255,255,.4)}
  .portal .backhint{position:absolute;bottom:30px;left:0;right:0;text-align:center;font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:#6b665c;opacity:0;transition:opacity .6s .5s}
  .portal.show .backhint{opacity:1}

  @media (prefers-reduced-motion: reduce){
    *{transition-duration:.001ms!important;animation-duration:.001ms!important}
  }
</style>
</head>
<body>
<div class="stage" id="stage">
  <div class="scene" id="scene">
    <div class="atmos dome"></div>
    <div class="atmos warm"></div>
    <div class="camera" id="camera">
      <div class="wall" id="wall"></div>
    </div>
    <div class="atmos floor"></div>
    <div class="atmos vignette"></div>
    <div class="grain"></div>

    <div class="pedestal">
      <div class="mark-halo"></div>
      <img class="mark" src="data:image/png;base64," alt="Arbor" />
      <div class="plinth"></div>
    </div>

    <div class="heading" id="heading">
      <h1>The Eight Dimensions of Arbor</h1>
      <p>Eight dimensions. One life. Entirely yours.</p>
    </div>
    <div class="hint" id="hint">Choose a direction</div>
  </div>
</div>

<script>
/* ---------------- data ---------------- */
const APPS = [
  { key:"nura",  name:"Nura",  dim:"Financial Wellbeing",  say:"Build a steady foundation.", accent:"#1F6F78" },
  { key:"wend",  name:"Wend",  dim:"Life Experiences",     say:"Explore what's out there.",  accent:"#F28C28" },
  { key:"salus", name:"Salus", dim:"Mental Wellbeing",     say:"Tend to your mind.",         accent:"#38C5A2" },
  { key:"aevo",  name:"Aevo",  dim:"Physical Wellbeing",   say:"Care for your body.",        accent:"#D4FF00" },
  { key:"telos", name:"Telos", dim:"Purpose & Contribution",say:"Move towards what matters.",accent:"#C89B3C" },
  { key:"sage",  name:"Sage",  dim:"Lifelong Growth",      say:"Keep learning, always.",     accent:"#5C6BC0" },
  { key:"kith",  name:"Kith",  dim:"Meaningful Connection", say:"Stay close to your people.", accent:"#D96C8A" },
  { key:"thrive",name:"Thrive",dim:"Intentional Living",   say:"Shape the space you live in.",accent:"#E85D5D" },
];

/* ---------------- illustrations (single-accent line art) ---------------- */
const ART = {
  // Aevo — flowing human form, organic curve, leaf, vitality (richly animated)
  aevo:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
    <g class="a-fig">
      <circle cx="50" cy="52" r="7"/>
      <path d="M50 59 C46 74 58 82 54 98 C51 112 60 120 57 136"/>
      <path d="M50 70 C40 76 33 70 27 74"/>
      <path d="M50 72 C61 78 68 71 75 76"/>
      <path d="M57 118 C50 128 44 132 39 146"/>
      <path d="M57 122 C64 132 66 140 70 154"/>
    </g>
    <path class="a-arc" d="M18 150 C40 120 60 120 82 150" stroke-dasharray="4 7"/>
    <g class="a-leaf" stroke-width="1.2">
      <path d="M74 60 C82 52 90 54 90 44 C82 44 74 50 74 60Z"/>
      <path d="M77 55 L86 48"/>
    </g>
    <line x1="14" y1="168" x2="86" y2="168"/>
  </svg>`,

  // Salus — breathing concentric rings + still-water reflection (richly animated)
  salus:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
    <line x1="12" y1="104" x2="88" y2="104" opacity=".5"/>
    <g class="s-breath">
      <circle cx="50" cy="80" r="10"/>
      <circle cx="50" cy="80" r="20" opacity=".7"/>
      <circle cx="50" cy="80" r="30" opacity=".45"/>
      <circle cx="50" cy="80" r="40" opacity=".25"/>
    </g>
    <g opacity=".55" class="s-ripple">
      <path d="M20 128 C34 122 44 132 50 128 C58 132 66 122 80 128"/>
      <path d="M22 142 C36 137 44 146 50 142 C58 146 66 137 78 142"/>
      <path d="M26 156 C38 151 45 159 50 156 C57 159 64 151 74 156"/>
    </g>
  </svg>`,

  // Telos — mountain path to a distant beacon (richly animated)
  telos:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <g class="t-beacon">
      <circle cx="50" cy="46" r="3.2"/>
      <path d="M50 40 L50 34 M50 52 L50 58 M44 46 L38 46 M56 46 L62 46" opacity=".8"/>
    </g>
    <path d="M14 150 L40 92 L52 116 L66 78 L88 150" />
    <path class="t-path" d="M50 150 C48 132 58 128 52 112 C48 100 56 92 50 78" stroke-dasharray="3 6"/>
    <line x1="12" y1="150" x2="88" y2="150" opacity=".6"/>
  </svg>`,

  // Nura — stable stacked forms + flowing path (foundations)
  nura:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <rect x="30" y="120" width="40" height="18" rx="2"/>
    <rect x="34" y="100" width="32" height="18" rx="2"/>
    <rect x="38" y="80" width="24" height="18" rx="2"/>
    <rect x="42" y="62" width="16" height="16" rx="2"/>
    <path d="M18 154 C34 150 40 158 50 154 C60 150 66 158 82 154" opacity=".6"/>
    <line x1="16" y1="140" x2="84" y2="140" opacity=".5"/>
  </svg>`,

  // Thrive — home / intentional space, gentle geometry
  thrive:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M28 108 L50 84 L72 108 L72 150 L28 150 Z"/>
    <path d="M44 150 L44 122 L56 122 L56 150"/>
    <line x1="20" y1="108" x2="80" y2="108" opacity=".4"/>
    <circle cx="50" cy="70" r="3" opacity=".7"/>
    <line x1="18" y1="150" x2="82" y2="150" opacity=".6"/>
  </svg>`,

  // Wend — winding path to a horizon, sun, moments
  wend:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="70" r="12"/>
    <line x1="20" y1="98" x2="80" y2="98" opacity=".5"/>
    <path d="M50 150 C40 138 62 130 52 118 C46 110 56 104 50 96"/>
    <circle cx="52" cy="118" r="1.6" opacity=".8"/>
    <circle cx="46" cy="134" r="1.6" opacity=".8"/>
  </svg>`,

  // Kith — connected forms, circles, relationships
  kith:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="50" cy="70" r="8"/>
    <circle cx="28" cy="104" r="6"/>
    <circle cx="72" cy="104" r="6"/>
    <circle cx="40" cy="140" r="6"/>
    <circle cx="66" cy="138" r="6"/>
    <path d="M46 76 L31 99 M55 76 L68 99 M31 110 L38 135 M68 109 L64 133 M45 138 L61 137" opacity=".55"/>
  </svg>`,

  // Sage — branching knowledge, growth, abstract structure
  sage:`<svg viewBox="0 0 100 200" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M50 152 L50 108"/>
    <path d="M50 118 C40 110 34 98 30 86 M50 108 C60 100 66 90 70 78 M50 128 C43 122 38 116 34 108 M50 122 C57 116 62 110 66 102"/>
    <circle cx="30" cy="86" r="3"/><circle cx="70" cy="78" r="3"/>
    <circle cx="34" cy="108" r="2.4"/><circle cx="66" cy="102" r="2.4"/>
    <circle cx="50" cy="104" r="3.2"/>
    <line x1="20" y1="152" x2="80" y2="152" opacity=".6"/>
  </svg>`,
};

/* ---------------- build the wall ---------------- */
const wall = document.getElementById("wall");
const stage = document.getElementById("stage");
const camera = document.getElementById("camera");
const N = APPS.length;
const STEP = 15;                 // degrees between windows
const RADIUS = 760;              // px
const start = -((N-1)/2)*STEP;

APPS.forEach((app,i)=>{
  const angle = start + i*STEP;
  const el = document.createElement("div");
  el.className = "window";
  el.style.setProperty("--accent", app.accent);
  el.style.transform = `rotateY(${angle}deg) translateZ(${RADIUS}px)`;
  el.innerHTML = `
    <div class="win-glow"></div>
    <div class="win-glass">
      <div class="win-art">${ART[app.key]||""}</div>
    </div>
    <div class="win-frame"></div>
    <div class="win-label">
      <div class="name">${app.name}</div>
      <div class="dim">${app.dim}</div>
      <div class="say">${app.say}</div>
    </div>`;
  el.addEventListener("mouseenter",()=>{ stage.classList.add("has-hover"); el.classList.add("active"); });
  el.addEventListener("mouseleave",()=>{ stage.classList.remove("has-hover"); el.classList.remove("active"); });
  el.addEventListener("click",()=> openApp(app, el));
  wall.appendChild(el);
});

/* ---------------- parallax look-around ---------------- */
let tx=0, ty=0, cx=0, cy=0;
window.addEventListener("pointermove",(e)=>{
  const nx=(e.clientX/window.innerWidth-.5);
  const ny=(e.clientY/window.innerHeight-.5);
  tx = nx*10;      // max deg
  ty = -ny*5;
});
(function loop(){
  cx += (tx-cx)*.05; cy += (ty-cy)*.05;
  camera.style.setProperty("--look-x", cx.toFixed(3)+"deg");
  camera.style.setProperty("--look-y", cy.toFixed(3)+"deg");
  requestAnimationFrame(loop);
})();

/* ---------------- cinematic travel-through transition ---------------- */
let portal=null, savedRect=null;
function openApp(app, el){
  if(portal) return;
  stage.classList.remove("has-hover"); el.classList.remove("active");
  const glass = el.querySelector(".win-glass");
  const r = glass.getBoundingClientRect();
  savedRect = r;

  portal = document.createElement("div");
  portal.className = "portal";
  portal.style.setProperty("--accent", app.accent);
  portal.style.top = r.top+"px"; portal.style.left = r.left+"px";
  portal.style.width = r.width+"px"; portal.style.height = r.height+"px";
  portal.innerHTML = `
    <div class="portal-wash"></div>
    <div class="portal-art">${ART[app.key]||""}</div>
    <button class="close" aria-label="Return to the observatory">&#10005;</button>
    <div class="landing">
      <div class="kicker">${app.dim}</div>
      <h2>${app.name}</h2>
      <p class="lede">${app.say}</p>
      <span class="enter">Enter ${app.name} &nbsp;&rarr;</span>
    </div>
    <div class="backhint">Esc to return to the observatory</div>`;
  document.body.appendChild(portal);

  stage.classList.add("zooming");
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    portal.classList.add("is-open");
  }));
  setTimeout(()=>portal && portal.classList.add("show"), 720);

  portal.querySelector(".close").addEventListener("click", closeApp);
  portal.querySelector(".enter").addEventListener("click", ()=>{
    // In the real Next site this navigates to /aevo, /salus, ...
    window.location.hash = app.key;
    flash(app.name);
  });
}
function closeApp(){
  if(!portal) return;
  const p=portal;
  p.classList.remove("show");
  p.classList.remove("is-open");
  if(savedRect){
    p.style.top=savedRect.top+"px"; p.style.left=savedRect.left+"px";
    p.style.width=savedRect.width+"px"; p.style.height=savedRect.height+"px";
    p.style.borderRadius="95px 95px 88px 88px";
  }
  stage.classList.remove("zooming");
  setTimeout(()=>{ p.remove(); }, 1000);
  portal=null;
}
document.addEventListener("keydown",(e)=>{ if(e.key==="Escape") closeApp(); });

function flash(name){
  const t=document.createElement("div");
  t.textContent="→ "+name+" landing page (wired to /"+name.toLowerCase()+" in the live site)";
  t.style.cssText="position:fixed;bottom:74px;left:50%;transform:translateX(-50%);z-index:40;font-size:12px;letter-spacing:.06em;color:#cfc8ba;background:rgba(0,0,0,.5);padding:8px 14px;border-radius:100px;border:1px solid rgba(255,255,255,.14)";
  document.body.appendChild(t); setTimeout(()=>t.remove(),2600);
}
</script>

<style>
  /* living motion */
  @keyframes breathe{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.06);opacity:.9}}
